# ======================================================
# StratLake Trade Engine - Environment Configuration
# ======================================================

# ------------------------------------------------------
# Required: Path to curated marketlake data
# This should point to the curated output directory
# from the fintech-market-ingestion repository.
#
# Example (Windows):
# MARKETLAKE_ROOT=C:/Users/Yourname/dev/fintech-market-ingestion/data/curated
#
# Example (Mac/Linux):
# MARKETLAKE_ROOT=/Users/Yourname/dev/fintech-market-ingestion/data/curated
# ------------------------------------------------------
MARKETLAKE_ROOT=/path/to/fintech-market-ingestion/data/curated


# ------------------------------------------------------
# Optional: DuckDB file location
# Default: in-memory database if not set
# ------------------------------------------------------
DUCKDB_PATH=:memory:


# ------------------------------------------------------
# Optional: Root directory for artifacts
# Backtest runs, feature runs, logs, summaries
# Default: ./artifacts
# ------------------------------------------------------
ARTIFACTS_ROOT=artifacts


# ------------------------------------------------------
# Optional: Root directory for locally generated features
# (Should NOT overlap with ingestion repo data)
# Default: ./data
# ------------------------------------------------------
FEATURES_ROOT=data


# ------------------------------------------------------
# Optional: Logging level
# Options: DEBUG | INFO | WARNING | ERROR
# Default: INFO
# ------------------------------------------------------
LOG_LEVEL=INFO


# ------------------------------------------------------
# Optional: Default timezone normalization
# Used if validation enforces UTC alignment
# Default: UTC
# ------------------------------------------------------
DEFAULT_TIMEZONE=UTC