# ===============================
# Python
# ===============================
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# ===============================
# Environment Variables
# ===============================
.env
.env.*
!.env.example

# ===============================
# Testing / Coverage
# ===============================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ===============================
# Linting / Formatting
# ===============================
.ruff_cache/

# ===============================
# Jupyter (if ever used)
# ===============================
.ipynb_checkpoints/

# ===============================
# DuckDB / Local DB
# ===============================
*.duckdb
*.duckdb.wal

# ===============================
# Data & Artifacts (LOCAL ONLY)
# ===============================
data/*
artifacts/*

# Keep directory structure
!data/.gitkeep
!artifacts/.gitkeep
!artifacts/strategies/
artifacts/strategies/*
!artifacts/strategies/.gitkeep

# ===============================
# Parquet (prevent accidental commits)
# ===============================
*.parquet

# ===============================
# Logs
# ===============================
*.log

# ===============================
# OS Noise
# ===============================
.DS_Store
Thumbs.db

# ===============================
# IDE
# ===============================
.vscode/
.idea/

