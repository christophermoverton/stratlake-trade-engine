{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pipeline Lineage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "edges",
    "nodes",
    "pipeline_run_id",
    "run_type",
    "schema_version"
  ],
  "properties": {
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "pipeline_run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_type": {
      "type": "string",
      "enum": ["pipeline_lineage"]
    },
    "schema_version": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "jsonValue": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ]
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "type"],
      "properties": {
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["depends_on", "produces"]
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "metadata", "type"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        "outputs": {
          "$ref": "#/$defs/jsonValue"
        },
        "type": {
          "type": "string",
          "enum": ["artifact", "dataset", "step"]
        }
      }
    }
  }
}
